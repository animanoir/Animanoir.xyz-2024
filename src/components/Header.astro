---
// import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE, SITE_SUBTITLE } from "@/consts";
import LastFm from "@/components/LastFm.jsx";
import Navbar from "@/components/Navbar.astro";
import Ornaments from "./Ornaments.astro";
---

<div class="sidebar-container">
  <header>
    <div class="header-content">
      <a href="/">
        <h2 id="headerTitle">
          <span id="headerSubtitle">{SITE_SUBTITLE} ∿ </span>
          {SITE_TITLE}
        </h2>
      </a>
      <LastFm client:load customStyle={{}} />
    </div>
  </header>
  <div class="navbar-wrapper">
    <Navbar />
  </div>
</div>
<Ornaments />
<style>
  .sidebar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: auto;
    height: 100vh;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    padding: 1rem var(--page-padding, 6%) 1rem calc(var(--page-padding, 6%) * 0.8);
    box-sizing: border-box;
    pointer-events: none;
  }

  .sidebar-container > * {
    pointer-events: auto;
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.475);
    margin-bottom: 1rem;
    width: auto;
  }

  .navbar-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  header a {
    text-decoration: none;
  }

  #headerTitle {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    padding: 0;
    line-height: 1.2;
    font-family: "Montserrat", sans-serif;
    user-select: none;
  }

  #headerSubtitle {
    font-weight: 400;
  }

  h1 {
    margin: 0.5em 0;
    color: #1c1c1c;
    transition: color 0.25s ease-out;
    cursor: pointer;
  }
  h1:hover {
    color: #ee5858;
  }

  @media (max-width: 768px) {
    .sidebar-container {
      padding: 1rem;
    }
    #headerTitle {
      font-size: 0.85rem;
    }
    #headerSubtitle {
      font-size: 0.85rem;
    }
  }
</style>
