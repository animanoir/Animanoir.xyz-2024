---
import "@/styles/global.css";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishDate?: string;
  author?: string;
  lang?: string;
  ogLocale?: string;
}
// Ensure canonical URL is properly formatted as a string
// Remove trailing slash for consistency (except for root)
const pathname =
  Astro.url.pathname.endsWith("/") && Astro.url.pathname !== "/"
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname;
const canonicalURL = new URL(pathname, Astro.site).href;

const {
  title,
  description,
  image = "/animanoir-oscar-a-montiel-tw.jpg",
  type = "website",
  publishDate,
  author = "Óscar A. Montiel",
} = Astro.props;

const siteTitle =
title === "Óscar A. Montiel" ? title : `Óscar A. Montiel ∿ ${title}`;
const fullImageUrl = new URL(image, Astro.site);

// Machine-readable identity for search engines (invisible to visitors). Emitted
// only on the homepage so crawlers get a clean "who/what" without us having to
// spell it out in visible copy. Person + WebSite are cross-linked via @id.
const siteHref = Astro.site?.href ?? "https://animanoir.xyz/";
const personId = `${siteHref}#person`;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteHref}#website`,
      url: siteHref,
      name: SITE_TITLE,
      description: SITE_DESCRIPTION,
      inLanguage: "en",
      publisher: { "@id": personId },
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Óscar A. Montiel",
      alternateName: ["Animanoir", "geosmina"],
      url: siteHref,
      image: fullImageUrl.href,
      jobTitle: "Creative Developer & Interactive Media Artist",
      description: SITE_DESCRIPTION,
      knowsAbout: [
        "Three.js",
        "React Three Fiber",
        "WebGL",
        "GLSL shaders",
        "Creative coding",
        "Generative art",
        "Interactive 3D",
        "Interactive installations",
        "Sound art",
        "Game development",
        "Videoart",
        "3D animation",
      ],
      sameAs: [
        "https://github.com/animanoir",
        "https://www.linkedin.com/in/oscaramontiel/",
        "https://www.youtube.com/channel/UCGe1qc0nF0uNypETYDQmMMQ",
        "https://twitter.com/geosminu",
        "https://steamcommunity.com/id/geosmina/",
        "https://www.are.na/tilde-colon-pipe-degrees-degrees-bullet-period-pipe-colon-tilde/channels",
      ],
    },
  ],
};
const isHomepage = pathname === "/";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta
  name="robots"
  content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
<meta name="language" content={Astro.props.lang ?? "en"} />
<link rel="icon" type="image/png" href="/animanoir-favicon-32x32.png" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={author} />
{publishDate && <meta name="article:published_time" content={publishDate} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:secure_url" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={description} />
<meta property="og:site_name" content="Óscar A. Montiel" />
<meta property="og:locale" content={Astro.props.ogLocale ?? "en_US"} />
{
  publishDate && (
    <meta property="article:published_time" content={publishDate} />
  )
}
{author && <meta property="article:author" content={author} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@geosminu" />
<meta name="twitter:creator" content="@geosminu" />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={description} />

<!-- Additional SEO -->
<meta name="theme-color" content="#000000" />
<meta name="msapplication-TileColor" content="#000000" />

<!-- Structured data (JSON-LD) — homepage only -->
{
  isHomepage && (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
  )
}

<script>
  import { handleAllImages } from "../scripts/imageLoader";

  // Runs when DOM is ready.
  document.addEventListener("DOMContentLoaded", handleAllImages);

  // Executes after page transition.
  document.addEventListener("astro:page-load", handleAllImages);
  document.addEventListener("astro:after-swap", handleAllImages);
</script>
