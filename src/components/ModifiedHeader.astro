---
import { SITE_TITLE } from "@/consts";
import LastFm from "@/components/LastFm.jsx";
import MutatingSubheader from "@/components/MutatingSubheader.jsx";
import Navbar from "@/components/Navbar.astro";
import Ornaments from "./Ornaments.astro";

const { goWild = false, sortSpeed = 0 } = Astro.props;
---

<header>
  <a href="/">
    <h2 id="headerTitle">
      {SITE_TITLE} | <span id="headerSubtitle"
        ><MutatingSubheader client:load /></span
      >
    </h2>
  </a>
  <LastFm client:load />
  <div class="navbar-wrapper">
    <Navbar />
  </div>
</header>
<Ornaments />
<style>
  header {
    position: relative;
    z-index: 10000;
    display: flex;
    position: fixed;
    flex-direction: column;

    justify-content: space-between;
    width: auto;
    box-sizing: border-box;
    padding: 0 var(--page-padding, 6%);
    margin-top: 2rem;
    left: 0;
  }
  .navbar-wrapper {
    position: fixed;
    left: var(--page-padding, 6%);
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
  }
  header a {
    text-decoration: none;
  }
  #headerTitle {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0;
    padding: 0;
    line-height: 1.2;
    font-family: "Bebas Neue", sans-serif;
    user-select: none;
    transition: color 0.25s ease-out;
  }

  header a:hover #headerTitle {
    color: #ee5858;
  }

  #headerSubtitle {
    font-weight: 400;
  }

  h1 {
    margin: 0.5em 0;
    color: #1c1c1c;
    transition: color 0.25s ease-out;
    cursor: pointer;
  }
  h1:hover {
    color: #ee5858;
  }

  @media (max-width: 500px) {
    header {
      flex-direction: column;
      align-items: left;
      padding-left: 1rem;
    }
    #headerTitle {
      font-size: 1rem;
    }
    #headerSubtitle {
      font-size: 1rem;
    }
    nav {
      font-size: 0.75em;
    }
  }
</style>
