---
import { SITE_TITLE } from "@/consts";
import LastFm from "@/components/LastFm.jsx";
import MutatingSubheader from "@/components/MutatingSubheader.jsx";
import Navbar from "@/components/Navbar.astro";
import Ornaments from "./Ornaments.astro";
import * as motion from "motion/react-client";

// `animated` opts into the sequential narrative reveal (quote → header → navbar).
// Only the homepage passes it; every other page renders the static markup.
const { goWild = false, sortSpeed = 0, animated = false } = Astro.props;
---

<header>
  {
    animated ? (
      <motion.div
        client:load
        initial={{ opacity: 0, x: 20 }}
        animate={{ opacity: 1, x: 0 }}
        transition={{ duration: 0.6, delay: 0.9, ease: "easeOut" }}
      >
        <a href="/">
          <h2 id="headerTitle">
            {SITE_TITLE} ∿{" "}
            <span id="headerSubtitle">
              <MutatingSubheader client:load goWild={goWild} sortSpeed={sortSpeed} />
            </span>
          </h2>
        </a>
        <LastFm client:load />
      </motion.div>
    ) : (
      <Fragment>
        <a href="/">
          <h2 id="headerTitle">
            {SITE_TITLE} ∿{" "}
            <span id="headerSubtitle">
              <MutatingSubheader client:load goWild={goWild} sortSpeed={sortSpeed} />
            </span>
          </h2>
        </a>
        <LastFm client:load />
      </Fragment>
    )
  }
  <div class="navbar-wrapper">
    <!-- When animated, the Navbar reveals its items one by one (right/left). -->
    <Navbar animated={animated} />
  </div>
</header>
<Ornaments />
<style>
  header {
    position: relative;
    z-index: 10000;
    display: flex;
    position: fixed;
    flex-direction: column;

    justify-content: space-between;
    width: auto;
    box-sizing: border-box;
    padding: 0 var(--page-padding, 6%) 0 calc(var(--page-padding, 6%) * 0.8);
    margin-top: 2rem;
    left: 0;
  }
  .navbar-wrapper {
    position: fixed;
    left: calc(var(--page-padding, 6%) * 0.8);
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
  }
  header a {
    text-decoration: none;
  }
  #headerTitle {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0;
    padding: 0;
    line-height: 1.2;
    font-family: "Bebas Neue", sans-serif;
    user-select: none;
    transition: color 0.25s ease-out;
  }

  header a:hover #headerTitle,
  header a:hover #headerSubtitle {
    color: #ee5858;
  }

  #headerSubtitle {
    font-weight: 400;
  }

  h1 {
    margin: 0.5em 0;
    color: #1c1c1c;
    transition: color 0.25s ease-out;
    cursor: pointer;
  }
  h1:hover {
    color: #ee5858;
  }

  @media (max-width: 500px) {
    header {
      flex-direction: column;
      align-items: left;
      padding-left: 1rem;
    }
    #headerTitle {
      font-size: 1.2rem;
    }
    #headerSubtitle {
      font-size: 1.2rem;
    }
    nav {
      font-size: 0.9em;
    }
  }
</style>
