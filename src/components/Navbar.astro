---
import HeaderLink from "@/components/HeaderLink.astro";
import { ClientRouter } from "astro:transitions";

// Work-related links
const workLinks = [
  { href: "/3Dworks", label: "3D Animation", target: "_self" },
  { href: "/videoart", label: "Video", target: "_self" },
  { href: "/interactiveart", label: "Interactive", target: "_self" },
  { href: "/works/2024/geosmina-music/", label: "Sound", target: "_self" },
];

// Personal content links
const personalLinks = [
  { href: "/blog", label: "Blog", target: "_self" },
  { href: "/photodiary", label: "Photodiary", target: "_self" },
  { href: "/aboutMe", label: "About", target: "_self" },
  { href: "https://linktr.ee/animanoir", label: "Contact", target: "_blank" },
];

// Combined for mobile menu
const allLinks = [...workLinks, ...personalLinks];
---

<nav class="navbar" role="navigation">
  <div class="nav-links">
    <!-- Work Links Group -->
    <div class="link-group">
      {
        workLinks.map((link) => (
          <div class="nav-item">
            <HeaderLink href={link.href} target={link.target}>
              {link.label}
            </HeaderLink>
          </div>
        ))
      }
    </div>

    <!-- Elegant Separator -->
    <div class="nav-separator">
      <span class="separator-line"></span>
    </div>

    <!-- Personal Links Group -->
    <div class="link-group">
      {
        personalLinks.map((link) => (
          <div class="nav-item">
            <HeaderLink href={link.href} target={link.target}>
              {link.label}
            </HeaderLink>
          </div>
        ))
      }
    </div>
  </div>
  <button class="mobile-menu-button" aria-label="Toggle mobile menu">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>
  <div class="mobile-menu">
    <div class="mobile-nav-links">
      <!-- Work Links -->
      {
        workLinks.map((link) => (
          <HeaderLink href={link.href} target={link.target}>
            {link.label}
          </HeaderLink>
        ))
      }

      <!-- Mobile Separator -->
      <div class="mobile-separator">
        <span class="mobile-separator-line"></span>
      </div>

      <!-- Personal Links -->
      {
        personalLinks.map((link) => (
          <HeaderLink href={link.href} target={link.target}>
            {link.label}
          </HeaderLink>
        ))
      }
    </div>
  </div>
  <ClientRouter />
</nav>

<script>
  function initializeMobileMenu() {
    const mobileMenuButton = document.querySelector(".mobile-menu-button");
    const mobileMenu = document.querySelector(".mobile-menu");
    const navbar = document.querySelector(".navbar");

    if (mobileMenuButton && mobileMenu) {
      // Remove existing event listeners to prevent duplicates
      const newButton = mobileMenuButton.cloneNode(true);
      if (!(newButton instanceof HTMLButtonElement)) {
        return;
      }
      mobileMenuButton.parentNode?.replaceChild(newButton, mobileMenuButton);

      newButton.addEventListener("click", () => {
        const isOpen = mobileMenu.classList.contains("open");

        if (isOpen) {
          mobileMenu.classList.remove("open");
          newButton.classList.remove("active");
          navbar?.classList.remove("menu-open");
        } else {
          mobileMenu.classList.add("open");
          newButton.classList.add("active");
          navbar?.classList.add("menu-open");
        }
      });

      // Close menu when clicking on a link
      const mobileNavLinks = mobileMenu.querySelectorAll("a");
      mobileNavLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.remove("open");
          newButton.classList.remove("active");
          navbar?.classList.remove("menu-open");
        });
      });
    }
  }

  // Initialize on page load
  document.addEventListener("DOMContentLoaded", initializeMobileMenu);

  // Reinitialize after Astro page transitions
  document.addEventListener("astro:page-load", initializeMobileMenu);
</script>

<style>
  :root {
    --text-color: #fdfefe;
    --hover-color: #ee5858;
    --font-size: 1rem;
    --margin-horizontal: 1rem;
    --margin-vertical: 1rem;
    --text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.475);
    --transition-speed: 0.3s;
    --bg-color: rgba(6, 6, 6, 0.95);
  }

  .navbar,
  .navbar a {
    text-shadow: var(--text-shadow);
  }

  .navbar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: "Cormorant Garamond", serif;
    gap: 0.75rem;
  }

  .nav-links {
    font-weight: bold;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    order: 1;
  }

  .link-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }

  /* Elegant separator between link groups */
  .nav-separator {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    width: 100%;
  }

  .separator-line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(253, 254, 254, 0.4) 20%,
      rgba(253, 254, 254, 0.7) 50%,
      rgba(253, 254, 254, 0.4) 80%,
      transparent 100%
    );
    position: relative;
  }

  /* Mobile separator */
  .mobile-separator {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 1rem 0;
  }

  .mobile-separator-line {
    display: block;
    width: 120px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(253, 254, 254, 0.4) 20%,
      rgba(253, 254, 254, 0.7) 50%,
      rgba(253, 254, 254, 0.4) 80%,
      transparent 100%
    );
    position: relative;
  }

  .mobile-separator-line::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    background: rgba(253, 254, 254, 0.9);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(253, 254, 254, 0.6);
  }

  .navbar a {
    color: var(--text-color);
    font-size: var(--font-size);
  }

  .navbar a:hover {
    color: var(--hover-color);
  }

  .navbar a:not(:last-child) {
    /* margin-right: var(--margin-horizontal); */
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    margin-right: 0;
  }

  .nav-item:last-child {
    margin-right: 0;
  }

  /* Mobile Menu Button */
  .mobile-menu-button {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 35px;
    height: 35px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    position: fixed;
    top: 80vh;
    right: 3.5rem;
  }

  .hamburger-line {
    width: 100%;
    height: 2px;
    background-color: var(--text-color);
    transition: all var(--transition-speed) ease;
    transform-origin: center;
  }

  .mobile-menu-button.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(6px, 6px);
  }

  .mobile-menu-button.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-button.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: -15px;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--bg-color);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition-speed) ease,
      visibility var(--transition-speed) ease;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav-links a {
    font-size: 1.5rem;
    text-decoration: none;
    color: var(--text-color);
    text-shadow: var(--text-shadow);
    transition: color var(--transition-speed);
  }

  .mobile-nav-links a:hover {
    color: var(--hover-color);
  }

  /* Media Queries */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .mobile-menu-button {
      display: flex;
    }

    .mobile-menu {
      display: flex;
    }

    .navbar {
      position: relative;
    }
  }
</style>
