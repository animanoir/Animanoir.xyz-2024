---
import HeaderLink from "@/components/HeaderLink.astro";
import { ClientRouter } from "astro:transitions";
import * as motion from "motion/react-client";

const isHomePage = Astro.url.pathname === "/";

// `animated` opts into the per-item narrative reveal — items slide in one by one,
// alternating from the right then the left. Only the homepage passes it; every
// other page renders the static markup (no React islands).
const { animated = false } = Astro.props;

// Reveal tuning. Base delay starts the navbar after the header reveal so the
// quote → header → navbar narrative keeps flowing.
const REVEAL_BASE_DELAY = 1.5;
const REVEAL_STEP = 0.1;
const REVEAL_OFFSET = 24;

// On the homepage these hashes drive the ProjectGrid filter; off the homepage
// they navigate home with the hash so the grid loads pre-filtered. The two
// featured areas (3D / Videoart) link straight to their own pages.
const workLinks = [
  { href: isHomePage ? "/#all" : "/", label: "All Works", target: "_self" },
  { href: "/3Dworks", label: "3D Animation", target: "_self" },
  { href: "/videoart", label: "VideoArt", target: "_self" },
  { href: "/#games", label: "Games & Play", target: "_self" },
  { href: "/#installations", label: "Art Installations", target: "_self" },
  { href: "/#sound-art", label: "Music & Sound", target: "_self" },
  { href: "/#web-design-dev", label: "Web Design/Dev", target: "_self" },
];

// "About" now lives on the homepage (#about section), so it's no longer a nav
// link — the standalone /aboutMe page still exists but is unlinked.
const personalLinks = [
  { href: "/blog", label: "Writing", target: "_self" },
  { href: "/photodiary", label: "Photodiary", target: "_self" },
];

// Downloadable CVs — one per role I take on. PDFs live in `public/cv/`, so the
// hrefs resolve at the site root. Open in a new tab so the visitor keeps the
// site. Replace these placeholders once the real files are dropped in.
const cvLinks = [
  { href: "https://docs.google.com/document/d/1_z6qVB2aFGpwAh-6SqUoq90lp_4uPvhhT6OXUG-MEqQ/edit?tab=t.0", label: "Fullstack Web Developer" },
  { href: "https://docs.google.com/document/d/13DbRDxHjGEKgoU2BNz3qVA6YtubAVguMu0b32RIIUZ0/edit?tab=t.0", label: "Creative Developer" },
];

// Continue the alternating reveal cadence past both link groups so the CV item
// slides in as the final navbar element.
const cvRevealIndex = workLinks.length + personalLinks.length;

// Combined for mobile menu
const allLinks = [...workLinks, ...personalLinks];
---

<nav class="navbar" role="navigation">
  <div class="nav-links">
    <!-- Work Links Group -->
    <div class="link-group">
      {
        workLinks.map((link, i) =>
          animated ? (
            <motion.div
              client:load
              initial={{ opacity: 0, x: i % 2 === 0 ? REVEAL_OFFSET : -REVEAL_OFFSET }}
              animate={{ opacity: 1, x: 0 }}
              transition={{
                duration: 0.6,
                delay: REVEAL_BASE_DELAY + i * REVEAL_STEP,
                ease: "easeOut",
              }}
            >
              <div class="nav-item">
                <HeaderLink href={link.href} target={link.target}>
                  {link.label}
                </HeaderLink>
              </div>
            </motion.div>
          ) : (
            <div class="nav-item">
              <HeaderLink href={link.href} target={link.target}>
                {link.label}
              </HeaderLink>
            </div>
          )
        )
      }
    </div>
    <div class="nav-separator"></div>
    <!-- Personal Links Group -->
    <div class="link-group">
      {
        personalLinks.map((link, i) => {
          // Continue the alternating right/left cadence across both groups.
          const idx = workLinks.length + i;
          return animated ? (
            <motion.div
              client:load
              initial={{ opacity: 0, x: idx % 2 === 0 ? REVEAL_OFFSET : -REVEAL_OFFSET }}
              animate={{ opacity: 1, x: 0 }}
              transition={{
                duration: 0.6,
                delay: REVEAL_BASE_DELAY + idx * REVEAL_STEP,
                ease: "easeOut",
              }}
            >
              <div class="nav-item">
                <HeaderLink href={link.href} target={link.target}>
                  {link.label}
                </HeaderLink>
              </div>
            </motion.div>
          ) : (
            <div class="nav-item">
              <HeaderLink href={link.href} target={link.target}>
                {link.label}
              </HeaderLink>
            </div>
          );
        })
      }
    </div>
    <!-- C.V. Dropdown — last item so the hover menu drops down unobstructed -->
    <div class="link-group cv-group">
      {
        animated ? (
          <motion.div
            client:load
            initial={{ opacity: 0, x: cvRevealIndex % 2 === 0 ? REVEAL_OFFSET : -REVEAL_OFFSET }}
            animate={{ opacity: 1, x: 0 }}
            transition={{
              duration: 0.6,
              delay: REVEAL_BASE_DELAY + cvRevealIndex * REVEAL_STEP,
              ease: "easeOut",
            }}
          >
            <div class="nav-item cv-dropdown">
              <button type="button" class="cv-trigger" aria-haspopup="true" aria-expanded="false">
                C.V.
                <span class="cv-caret" aria-hidden="true">▾</span>
              </button>
              <ul class="cv-menu" role="menu">
                {cvLinks.map((cv) => (
                  <li role="none">
                    <a role="menuitem" href={cv.href} target="_blank" rel="noopener noreferrer">
                      {cv.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </motion.div>
        ) : (
          <div class="nav-item cv-dropdown">
            <button type="button" class="cv-trigger" aria-haspopup="true" aria-expanded="false">
              C.V.
              <span class="cv-caret" aria-hidden="true">▾</span>
            </button>
            <ul class="cv-menu" role="menu">
              {cvLinks.map((cv) => (
                <li role="none">
                  <a role="menuitem" href={cv.href} target="_blank" rel="noopener noreferrer">
                    {cv.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>
  <button class="mobile-menu-button" aria-label="Toggle mobile menu">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>
  <div class="mobile-menu">
    <div class="mobile-nav-links">
      <!-- Work Links -->
      {
        workLinks.map((link) => (
          <HeaderLink href={link.href} target={link.target}>
            {link.label}
          </HeaderLink>
        ))
      }

      <!-- Mobile Separator -->
      <div class="mobile-separator">
        <span class="mobile-separator-line"></span>
      </div>

      <!-- Disabled Link -->
      <div class="disabled-link mobile-disabled">
        <span>Web Design & Development</span>
        <span class="under-construction">under construction</span>
      </div>

      <!-- Mobile Separator -->
      <div class="mobile-separator">
        <span class="mobile-separator-line"></span>
      </div>

      <!-- Personal Links -->
      {
        personalLinks.map((link) => (
          <HeaderLink href={link.href} target={link.target}>
            {link.label}
          </HeaderLink>
        ))
      }

      <!-- Mobile Separator -->
      <div class="mobile-separator">
        <span class="mobile-separator-line"></span>
      </div>

      <!-- C.V. Links (flat on mobile — no hover affordance on touch) -->
      <span class="mobile-cv-label">C.V.</span>
      {
        cvLinks.map((cv) => (
          <a class="mobile-cv-link" href={cv.href} target="_blank" rel="noopener noreferrer">
            {cv.label}
          </a>
        ))
      }
    </div>
  </div>
  <ClientRouter />
</nav>

<script>
  function initializeMobileMenu() {
    const mobileMenuButton = document.querySelector(".mobile-menu-button");
    const mobileMenu = document.querySelector(".mobile-menu");
    const navbar = document.querySelector(".navbar");

    if (mobileMenuButton && mobileMenu) {
      // Remove existing event listeners to prevent duplicates
      const newButton = mobileMenuButton.cloneNode(true);
      if (!(newButton instanceof HTMLButtonElement)) {
        return;
      }
      mobileMenuButton.parentNode?.replaceChild(newButton, mobileMenuButton);

      newButton.addEventListener("click", () => {
        const isOpen = mobileMenu.classList.contains("open");

        if (isOpen) {
          mobileMenu.classList.remove("open");
          newButton.classList.remove("active");
          navbar?.classList.remove("menu-open");
        } else {
          mobileMenu.classList.add("open");
          newButton.classList.add("active");
          navbar?.classList.add("menu-open");
        }
      });

      // Close menu when clicking on a link
      const mobileNavLinks = mobileMenu.querySelectorAll("a");
      mobileNavLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.remove("open");
          newButton.classList.remove("active");
          navbar?.classList.remove("menu-open");
        });
      });
    }
  }

  // CSS handles the hover-open for mouse users; this wires click + keyboard
  // (Enter/Space toggles, Escape closes, outside-click closes) for everyone else.
  function initializeCvDropdown() {
    const dropdown = document.querySelector(".cv-dropdown");
    const trigger = dropdown?.querySelector(".cv-trigger");
    if (!dropdown || !(trigger instanceof HTMLButtonElement)) return;

    // Avoid stacking listeners across Astro page transitions.
    const freshTrigger = trigger.cloneNode(true);
    if (!(freshTrigger instanceof HTMLButtonElement)) return;
    trigger.parentNode?.replaceChild(freshTrigger, trigger);

    const close = () => {
      dropdown.classList.remove("open");
      freshTrigger.setAttribute("aria-expanded", "false");
    };

    freshTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle("open");
      freshTrigger.setAttribute("aria-expanded", String(isOpen));
    });

    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target as Node)) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }

  // The footer is always black, but most pages have a light background — so the
  // fixed header/navbar/LastFm text must flip to white while the footer covers
  // the viewport. An IntersectionObserver watches the footer and toggles
  // `footer-in-view` on <body>; the global styles below do the color flip.
  let footerObserver: IntersectionObserver | null = null;

  function initializeFooterColorFlip() {
    // Drop the previous page's observer (Astro page transitions).
    footerObserver?.disconnect();
    document.body.classList.remove("footer-in-view");

    const footer = document.querySelector("footer");
    if (!footer) return;

    footerObserver = new IntersectionObserver(
      ([entry]) => {
        document.body.classList.toggle("footer-in-view", entry.isIntersecting);
      },
      // Shrink the observation root to the top half of the viewport — where the
      // fixed header and navbar live. The flip then happens exactly when the
      // footer's black background slides up underneath them, not as soon as the
      // footer merely peeks in at the bottom.
      { rootMargin: "0px 0px -50% 0px" },
    );
    footerObserver.observe(footer);
  }

  // Initialize on page load
  document.addEventListener("DOMContentLoaded", initializeMobileMenu);
  document.addEventListener("DOMContentLoaded", initializeCvDropdown);
  document.addEventListener("DOMContentLoaded", initializeFooterColorFlip);

  // Reinitialize after Astro page transitions
  document.addEventListener("astro:page-load", initializeMobileMenu);
  document.addEventListener("astro:page-load", initializeCvDropdown);
  document.addEventListener("astro:page-load", initializeFooterColorFlip);
</script>

<!-- Global (unscoped): flips the fixed header / navbar / LastFm to white while
     the black footer covers the viewport (body.footer-in-view, toggled by the
     IntersectionObserver above). Global because it must reach elements outside
     the Navbar — the header title and the LastFm island. `!important` mirrors
     the per-page dark-background overrides (e.g. index.astro) so the flip wins
     everywhere; on pages already forcing white it's a visual no-op. -->
<style is:global>
  /* Smooth the flip in both directions. */
  #headerTitle,
  #headerSubtitle,
  .navbar a,
  .cv-trigger,
  .mobile-nav-links a,
  .lastfmContainer,
  .songInfo,
  .lastFmDash {
    transition: color 0.4s ease;
  }

  body.footer-in-view #headerTitle,
  body.footer-in-view #headerSubtitle,
  body.footer-in-view header h2 {
    color: #f2f0eb !important;
  }
  body.footer-in-view header a:hover #headerTitle,
  body.footer-in-view header a:hover #headerSubtitle {
    color: #ee5858 !important;
  }
  body.footer-in-view .navbar a,
  body.footer-in-view .cv-trigger,
  body.footer-in-view .mobile-nav-links a,
  body.footer-in-view .mobile-cv-label,
  body.footer-in-view .mobile-cv-link {
    color: #f2f0eb !important;
  }
  body.footer-in-view .navbar a:hover,
  body.footer-in-view .cv-trigger:hover,
  body.footer-in-view .mobile-nav-links a:hover,
  body.footer-in-view .mobile-cv-link:hover {
    color: #ee5858 !important;
  }
  body.footer-in-view .hamburger-line {
    background-color: #f2f0eb !important;
  }
  body.footer-in-view .separator-line,
  body.footer-in-view .mobile-separator-line {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(242, 240, 235, 0.4) 20%,
      rgba(242, 240, 235, 0.7) 50%,
      rgba(242, 240, 235, 0.4) 80%,
      transparent 100%
    ) !important;
  }
  body.footer-in-view .mobile-separator-line::before {
    background: rgba(242, 240, 235, 0.9) !important;
    box-shadow: 0 0 12px rgba(242, 240, 235, 0.6) !important;
  }
  body.footer-in-view .ornaments .circle {
    background-color: #f2f0eb !important;
  }
  body.footer-in-view .lastfmContainer {
    color: rgba(255, 255, 255, 0.4) !important;
  }
  body.footer-in-view .songInfo {
    color: #f2f0ebd9 !important;
  }
  body.footer-in-view .lastFmDash {
    color: rgba(255, 255, 255, 0.4) !important;
  }
  body.footer-in-view .lastFmLink {
    text-decoration-color: #f2f0eb75 !important;
  }
</style>

<style>
  :root {
    --text-color: #1c1c1c;
    --hover-color: #ee5858;
    --font-size: 0.9rem;
    --margin-horizontal: 1rem;
    --margin-vertical: 1rem;
    --transition-speed: 0.3s;
    --bg-color: rgba(242, 240, 235, 0.95);
  }

  .navbar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* Same face as the Quote's subtitle line (.hero-sub) on the homepage. */
    font-family: "Montserrat", sans-serif;
    gap: 0.75rem;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    order: 1;
  }

  .link-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }

  /* Elegant separator between link groups */
  .nav-separator {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    width: 100%;
  }

  .separator-line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(28, 28, 28, 0.4) 20%,
      rgba(28, 28, 28, 0.7) 50%,
      rgba(28, 28, 28, 0.4) 80%,
      transparent 100%
    );
    position: relative;
  }

  /* Mobile separator */
  .mobile-separator {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 1rem 0;
  }

  .mobile-separator-line {
    display: block;
    width: 120px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(28, 28, 28, 0.4) 20%,
      rgba(28, 28, 28, 0.7) 50%,
      rgba(28, 28, 28, 0.4) 80%,
      transparent 100%
    );
    position: relative;
  }

  .mobile-separator-line::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    background: rgba(28, 28, 28, 0.9);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(28, 28, 28, 0.6);
  }

  .navbar a {
    color: var(--text-color);
    font-size: var(--font-size);
  }

  .navbar a:hover {
    color: var(--hover-color);
  }

  .navbar a:not(:last-child) {
    /* margin-right: var(--margin-horizontal); */
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    margin-right: 0;
  }

  .disabled-link {
    display: flex;
    flex-direction: column;
    color: #999;
    font-size: var(--font-size);
    cursor: default;
    font-weight: bold;
  }

  .disabled-link .under-construction {
    font-size: 0.7rem;
    font-style: italic;
    font-weight: normal;
    color: #bbb;
  }

  .mobile-disabled {
    align-items: center;
    font-size: 1.5rem;
  }

  .mobile-disabled .under-construction {
    font-size: 0.85rem;
  }

  .nav-item:last-child {
    margin-right: 0;
  }

  /* ---- C.V. Dropdown (desktop) ---- */
  .cv-group {
    /* Slight breathing room so the CV trigger reads as its own affordance. */
    margin-top: 0.75rem;
  }

  .cv-dropdown {
    position: relative;
  }

  .cv-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0;
    margin: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-color);
    font-family: inherit;
    font-size: var(--font-size);
    line-height: 1;
  }

  .cv-trigger:hover {
    color: var(--hover-color);
  }

  .cv-caret {
    font-size: 0.7em;
    transition: transform var(--transition-speed) ease;
  }

  .cv-dropdown:hover .cv-caret,
  .cv-dropdown.open .cv-caret {
    transform: rotate(180deg);
  }

  .cv-menu {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
    position: absolute;
    top: calc(100% + 0.4rem);
    left: 0;
    min-width: 11rem;
    /* The dropdown is locked to a dark surface regardless of the page's dynamic
       navbar color (some pages flip the links to off-white via `:global(.navbar a)
       !important`, which also hits the items here). A fixed dark panel + light
       text keeps the menu readable on both light and dark backgrounds. */
    background-color: black;
    border: 1px solid rgba(242, 240, 235, 0.14);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
    /* Hidden until hover / focus / click-open. opacity+visibility keeps it
       animatable and out of the tab order while closed. */
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity var(--transition-speed) ease,
      transform var(--transition-speed) ease,
      visibility var(--transition-speed) ease;
    z-index: 1000;
  }

  .cv-dropdown:hover .cv-menu,
  .cv-dropdown:focus-within .cv-menu,
  .cv-dropdown.open .cv-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .cv-menu a {
    display: block;
    padding: 0.4rem 1rem;
    /* Off-white, fixed — matches the site's "white" and the value the dark-page
       override already forces, so the menu text reads the same everywhere. */
    color: #f2f0eb;
    font-size: var(--font-size);
    white-space: nowrap;
    transition: color var(--transition-speed) ease;
  }

  .cv-menu a:hover {
    color: var(--hover-color);
  }

  /* ---- C.V. Links (mobile) ---- */
  .mobile-cv-label {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--text-color);
    margin-bottom: 0.25rem;
  }

  .mobile-cv-link {
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--text-color);
    transition: color var(--transition-speed);
  }

  .mobile-cv-link:hover {
    color: var(--hover-color);
  }

  /* Mobile Menu Button */
  .mobile-menu-button {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 35px;
    height: 35px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    position: fixed;
    top: 2rem;
    right: 1.5rem;
  }

  .hamburger-line {
    width: 100%;
    height: 2px;
    background-color: var(--text-color);
    transition: all var(--transition-speed) ease;
    transform-origin: center;
  }

  .mobile-menu-button.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(6px, 6px);
  }

  .mobile-menu-button.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-button.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background-color: var(--bg-color);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition-speed) ease,
      visibility var(--transition-speed) ease;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav-links a {
    font-size: 1.5rem;
    text-decoration: none;
    color: var(--text-color);
    transition: color var(--transition-speed);
  }

  .mobile-nav-links a:hover {
    color: var(--hover-color);
  }

  /* Media Queries */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .mobile-menu-button {
      display: flex;
    }

    .mobile-menu {
      display: flex;
    }

    .navbar {
      position: relative;
    }
  }
</style>
