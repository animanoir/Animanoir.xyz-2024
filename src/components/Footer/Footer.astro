---
const today = new Date();
import { Image } from "astro:assets";
import youtubeSvg from "./icons/youtube.svg";
import linkedinSvg from "./icons/linkedin.svg";
import arenaLogo from "./icons/arena-logo-white.png";
import steamSvg from "./icons/steam.svg";

const socialLinks = [
  {
    href: "https://www.are.na/tilde-colon-pipe-degrees-degrees-bullet-period-pipe-colon-tilde/channels",
    icon: arenaLogo,
    alt: "Are.na profile",
  },
  {
    href: "https://www.linkedin.com/in/oscaramontiel/",
    icon: linkedinSvg,
    alt: "LinkedIn profile",
  },
  {
    href: "https://www.youtube.com/channel/UCGe1qc0nF0uNypETYDQmMMQ",
    icon: youtubeSvg,
    alt: "YouTube channel",
  },
  {
    href: "https://steamcommunity.com/id/geosmina/",
    icon: steamSvg,
    alt: "Steam profile",
  },
];
---

<footer>
  <div class="social-icons">
    {
      socialLinks.map((social) => (
        <a
          href={social.href}
          target="_blan
          margin-bottom:1050px;k"
          rel="noreferrer"
          class="social-link"
        >
          <Image
            loading="eager"
            alt={social.alt}
            src={social.icon}
            class="social-icon"
          />
        </a>
      ))
    }
  </div>
  <div>
    {today.getFullYear()} · Mexico
  </div>
</footer>

<style>
  .social-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 10px;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    transition: opacity 0.3s ease;
  }

  .social-link:hover {
    opacity: 0.7;
  }

  .social-icon {
    height: 24px;
    width: auto;
  }

  footer {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-family: "Cormorant Garamond", serif;
    color: #fdfefe;
    font-size: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: auto;
    box-sizing: border-box;
    position: relative;
  }

  /* Mobile responsive styles */
  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      padding: 1.5rem;
      text-align: center;
      font-size: 0.7rem;
    }

    .social-icons {
      gap: 1.5rem;
    }

    .social-icon {
      height: 20px;
    }
  }

  /* Small mobile devices */
  @media (max-width: 480px) {
    footer {
      font-size: 0.6rem;
      padding: 1rem;
    }

    .social-icons {
      gap: 1rem;
    }

    .social-icon {
      height: 18px;
    }
  }
</style>
