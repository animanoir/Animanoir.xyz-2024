---
const today = new Date();
import { Image } from "astro:assets";
import portrait from "@/images/about/oam-optim.webm";
import youtubeSvg from "./icons/youtube.svg";
import linkedinSvg from "./icons/linkedin.svg";
import arenaLogo from "./icons/arena-logo-white.png";
import steamSvg from "./icons/steam.svg";
import githubSvg from "./icons/github.svg";

const socialLinks = [
  {
    href: "https://github.com/animanoir",
    icon: githubSvg,
    alt: "GitHub profile",
  },
  {
    href: "https://www.linkedin.com/in/oscaramontiel/",
    icon: linkedinSvg,
    alt: "LinkedIn profile",
  },
  {
    href: "https://www.youtube.com/channel/UCGe1qc0nF0uNypETYDQmMMQ",
    icon: youtubeSvg,
    alt: "YouTube channel",
  },
  {
    href: "https://steamcommunity.com/id/geosmina/",
    icon: steamSvg,
    alt: "Steam profile",
  },
];
---
<footer>
  <video
    class="footer-portrait"
    src={portrait}
    autoplay
    loop
    muted
    playsinline
    width={360}
    height={360}></video>
  <div class="social-icons">
    {
      socialLinks.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noreferrer"
          class="social-link"
        >
          <Image
            loading="eager"
            alt={social.alt}
            src={social.icon}
            class="social-icon"
          />
        </a>
      ))
    }
  </div>
  <a
    href="mailto:etherealflux94@gmail.com"
    class="email-link"
  >
    etherealflux94@gmail.com
  </a>
  <div>
    {today.getFullYear()} · Mexico
  </div>
</footer>
<style>
  .footer-portrait {
    display: block;
    width: 360px;
    max-width: 55vw;
    height: auto;
    margin-bottom: 2rem;
  }
  .email-link {
    color: inherit;
    text-decoration: none;
    font-size: 2rem!important;
    transition: opacity 0.3s ease;
  }
  .email-link:hover {
    opacity: 0.7;
  }
  .social-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 10px;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    transition: opacity 0.3s ease;
  }
  .social-link:hover {
    opacity: 0.7;
  }
  .social-icon {
    height: 24px;
    width: auto;
    filter: brightness(0.11);
  }
  footer {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-family: "Cormorant Garamond", serif;
    color: #1c1c1c;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: auto;
    box-sizing: border-box;
    position: relative;
  }
  /* Mobile responsive styles */
  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      padding: 1.5rem;
      text-align: center;
      font-size: 1.12rem;
    }
    .social-icons {
      gap: 1.5rem;
    }

    .social-icon {
      height: 32px;
    }
  }
  /* Small mobile devices */
  @media (max-width: 480px) {
    footer {
      font-size: 0.96rem;
      padding: 1rem;
    }
    .social-icons {
      gap: 1rem;
    }
    .social-icon {
      height: 28.8px;
    }
  }
</style>
