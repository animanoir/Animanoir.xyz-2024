---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import ModifiedHeader from "../components/ModifiedHeader.astro";
import { Picture } from "astro:assets";
import Footer from "@/components/Footer/Footer.astro";

type HeroImage = {
  src: string;
  width: number;
  height: number;
  format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
};

type Props = CollectionEntry<"works">["data"] & {
  heroImage?: HeroImage;
};

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={heroImage?.src}
      type="article"
      author="Óscar A. Montiel"
    />
  </head>
  <body>
    <ModifiedHeader />
    <main>
      <div class:list={["top-section", { "no-hero": !heroImage }]}>
        {
          heroImage && (
            <div class="gradient-black">
              <Picture
                src={heroImage}
                alt={description}
                class="heroImage"
                formats={["webp"]}
                decoding="async"
                loading="eager"
                quality={80}
              />
            </div>
          )
        }
        <div class="project-description-container">
          <h1 class="title">{title}</h1>
          <h3>{description}</h3>
        </div>
      </div>
      <article class="articleContainer">
        <div class="articleBody">
          <slot />
        </div>
      </article>
    </main>
    <Footer useTopOffset={false} />
    <style>
      body {
        margin: 0;
        overflow-x: hidden; /* Prevent horizontal scrolling */
      }

      main {
        margin-left: 10vw;
      }

      .top-section {
        display: flex;
        position: relative;
        justify-content: center;
        align-items: center;
        width: 80%;
        margin: 0 auto;
        height: 100vh;
      }

      /* Imageless work: drop the full-height hero stage and just show the
         title/description near the top (clearing the fixed header). */
      .top-section.no-hero {
        display: block;
        height: auto;
        padding-top: 22vh;
        padding-bottom: 4vh;
        /* Mirror .articleContainer so the title/description share the body's
           column width instead of the wider 80% hero stage. */
        width: 100%;
      }

      .top-section.no-hero .project-description-container {
        /* The default -50% pull overlays the text on the faded image edge;
           with no image it would shove the text off to the left. Instead,
           match .articleBody (90% of the column, centered) so the heading's
           left edge aligns with the article text below it. */
        transform: none;
        width: 90%;
        margin: 0 auto;
      }

      .gradient-black {
        position: relative;
        width: 100%;
      }

      .gradient-black::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
          to left,
          rgba(242, 240, 235, 1) 0%,
          rgba(242, 240, 235, 0.5) 40%,
          transparent 100%
        );
        z-index: 1;
        pointer-events: none;
      }

      .heroImage {
        height: 100%;
        width: 100%;
        object-fit: cover;
        filter: brightness(0.9);
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
        position: relative;
        z-index: 0;
      }
      .heroImage.loaded {
        opacity: 1;
      }

      .title {
        width: 100%;
        margin: 0;
        font-size: 3.5rem;
        font-family: "Bebas Neue", sans-serif;
        letter-spacing: 0.5rem;
        line-height: 1;
        /* position: absolute; */
        top: 50%;
        left: 50%;
        color: #1c1c1c;
        z-index: 2;
      }

      .project-description-container {
        transform: translate(-50%, 0);
        z-index: 3;
      }

      .project-description-container h3 {
        font-family: "Bebas Neue", sans-serif;
        font-weight: normal;
        margin-top: 0.1rem;
        font-size: 1.2rem;
        opacity: 0.5;
      }

      .articleContainer {
        padding-bottom: 40vh;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        width: 100%;
      }

      .articleBody {
        font-family: "Cormorant Garamond", serif;
        color: #1c1c1c;
        font-size: 1.45rem;
        width: 90%;
        margin: 0 auto;
        line-height: 1.8;
      }

      .articleBody :global(p) {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        margin-top: 1.8rem !important;
        margin-bottom: 2.4rem !important;
      }

      .articleBody :global(h2),
      .articleBody :global(h3),
      .articleBody :global(h4) {
        margin-top: 4.2rem !important;
        margin-bottom: 1.8rem !important;
      }

      .articleBody :global(img),
      .articleBody :global(video),
      .articleBody :global(lite-youtube) {
        margin: 3.6rem 0 !important;
      }

      .articleContainer h1 {
        font-size: 4rem;
        width: 50%;
      }

      hr {
        border-top: 1px solid #ddd;
        margin: 1rem 0;
      }

      @media (max-width: 1920px) {
        .articleContainer {
          width: 60%;
        }
        .top-section.no-hero {
          width: 60%;
        }
      }

      @media (max-width: 768px) {
        .project-description-container h3 {
          font-size: 1rem;
        }
        .top-section {
          flex-direction: column;
          margin-top: 40%;
          width: 90%;
        }
        /* margin-top: 40% already clears the header on mobile. */
        .top-section.no-hero {
          padding-top: 0;
        }
        .gradient-black::before {
          background: linear-gradient(
            to top,
            rgba(242, 240, 235, 1) 0%,
            rgba(242, 240, 235, 0.5) 40%,
            transparent 100%
          );
        }
        .project-description-container {
          transform: initial;
        }
        /* Stay matched to .articleContainer (100%) / .articleBody (95%). */
        .top-section.no-hero {
          width: 100%;
        }
        .top-section.no-hero .project-description-container {
          width: 95%;
        }
        .title {
          transform: initial;
          top: initial;
          left: initial;
        }
        .title {
          font-size: 2.5rem;
        }
        .articleContainer {
          width: 100%;
        }
        .articleBody {
          width: 95%;
          font-size: 1.1rem;
        }
        main {
          margin-left: 0;
        }
      }

      @media (max-width: 480px) {
        .top-section {
          flex-direction: column;
          height: auto;
          width: 90%;
        }
        .project-description-container {
          text-align: center;
          margin-top: 1rem;
        }
        .title {
          font-size: 2rem;
          text-align: center;
        }
        .articleContainer {
          width: 100%;
          padding-top: 5vh;
          padding-bottom: 20vh;
        }
        .articleBody {
          width: 100%;
          padding: 0 1rem;
          box-sizing: border-box;
          font-size: 1rem;
        }
        .heroImage {
          height: auto;
          max-height: 300px;
          width: 100%;
        }
      }
    </style>
  </body>
</html>
