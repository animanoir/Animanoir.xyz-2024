---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import ModifiedHeader from "../components/ModifiedHeader.astro";
import Picture from "astro/components/Picture.astro";
import RelatedArticles from "@/components/RelatedArticles.astro";

type Props = CollectionEntry<"blog">["data"] & {
  slug?: string;
};

const { title, summary, pubDate, heroImage, tags, slug } = Astro.props;

// Extract the actual slug from the URL if not provided
const actualSlug =
  slug || Astro.url.pathname.split("/").filter(Boolean).pop() || "";
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={summary ??
        "Blog post by Óscar A. Montiel: interactive media artist."}
      image={heroImage?.src}
      type="article"
      publishDate={pubDate?.toISOString()}
      author="Óscar A. Montiel"
    />
    {
      heroImage && (
        <link
          rel="preload"
          as="image"
          href={heroImage.src}
          fetchpriority="high"
        />
      )
    }
  </head>
  <body class={heroImage ? "has-hero" : ""}>
    <ModifiedHeader />
    {
      heroImage &&
        (heroImage.format ? (
          <Picture
            class="heroimage"
            src={heroImage}
            alt={title}
            quality={50}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        ) : (
          <img
            class="heroimage"
            src={heroImage.src}
            alt={title}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        ))
    }
    <div class="articleBody">
      <article class="articleContainer">
        <div class="top-container">
          <div class="title-container">
            <h1 class="title">{title}</h1>
            <h2 class="summary">{summary}</h2>
            <time class="postDate">
              {new Date(pubDate).toLocaleDateString()}
            </time>
          </div>
          <div class="related-container">
            <RelatedArticles
              currentTags={tags}
              currentUrl={Astro.url.pathname}
              currentSlug={actualSlug}
              maxResults={3}
            />
          </div>
        </div>
        <slot />
        {
          heroImage && (
            <a
              href={heroImage.src}
              target="_blank"
              rel="noopener noreferrer"
              class="end-hero-link"
            >
              {heroImage.format ? (
                <Picture
                  class="end-hero-image"
                  src={heroImage}
                  alt={title}
                  quality={50}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <img
                  class="end-hero-image"
                  src={heroImage.src}
                  alt={title}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </a>
          )
        }
      </article>
    </div>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap");
      @import url("https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Space+Grotesk:wght@300..700&display=swap");

      /* ==========================================================================
         HEADER / NAVBAR LEGIBILITY OVER DARK HERO
         The hero image is used as a darkened full-viewport background, so the
         header and navbar (which default to dark text) need to be forced light
         to stay readable. Mirrors the approach used in photodiary.astro.
         ========================================================================== */
      :global(body.has-hero header #headerTitle),
      :global(body.has-hero header #headerSubtitle),
      :global(body.has-hero header h1),
      :global(body.has-hero header h2) {
        color: #f2f0eb !important;
      }
      :global(body.has-hero header a:hover #headerTitle),
      :global(body.has-hero header a:hover #headerSubtitle) {
        color: #ee5858 !important;
      }
      :global(body.has-hero .navbar a),
      :global(body.has-hero .mobile-nav-links a) {
        color: #f2f0eb !important;
      }
      :global(body.has-hero .navbar a:hover),
      :global(body.has-hero .mobile-nav-links a:hover) {
        color: #ee5858 !important;
      }
      :global(body.has-hero .hamburger-line) {
        background-color: #f2f0eb !important;
      }
      :global(body.has-hero .mobile-menu) {
        background-color: rgba(6, 6, 6, 0.95) !important;
      }
      :global(body.has-hero .ornaments .circle) {
        background-color: #f2f0eb !important;
      }
      :global(body.has-hero .separator-line),
      :global(body.has-hero .mobile-separator-line) {
        background: linear-gradient(
          90deg,
          transparent 0%,
          rgba(242, 240, 235, 0.4) 20%,
          rgba(242, 240, 235, 0.7) 50%,
          rgba(242, 240, 235, 0.4) 80%,
          transparent 100%
        ) !important;
      }
      :global(body.has-hero .mobile-separator-line)::before {
        background: rgba(242, 240, 235, 0.9) !important;
        box-shadow: 0 0 12px rgba(242, 240, 235, 0.6) !important;
      }
      :global(body.has-hero .lastfmContainer) {
        color: rgba(255, 255, 255, 0.224) !important;
      }
      :global(body.has-hero .songInfo) {
        color: #f2f0eb8f !important;
      }
      :global(body.has-hero .lastFmDash) {
        color: rgba(255, 255, 255, 0.224) !important;
      }
      :global(body.has-hero .lastFmLink) {
        text-decoration-color: #f2f0eb75 !important;
      }
      :global(body.has-hero .social-icon) {
        filter: none !important;
      }
      :global(body.has-hero footer) {
        color: #f2f0eb !important;
      }

      /* ==========================================================================
         ARTICLE CONTAINER
         Main container for blog post content
         ========================================================================== */
      .heroimage {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        filter:  brightness(0.1);
        z-index: 1;
        /* Placeholder background while image loads */
        background: linear-gradient(
          135deg,
          #1a1a2e 0%,
          #16213e 50%,
          #0f0f23 100%
        );
        /* Smooth fade-in animation when loaded */
        animation: heroFadeIn 0.3s ease-out;
      }

      @keyframes heroFadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      .end-hero-link {
        display: block;
        width: 100%;
      }
      .end-hero-image {
        width: 100%;
        height: auto;
        margin-top: 2rem;
        border-radius: 8px;
        transition: opacity 0.3s ease;
      }
      .end-hero-image:hover {
        opacity: 0.9;
      }
      .articleContainer {
        margin: 0 auto;
        margin-right: 10rem;
        position: relative;
        max-width: 60%;
        font-size: 1.5rem;
        z-index: 10;
      }
      .articleContainer h2 {
        margin-top: 0 !important;
      }
      .top-container {
        width: 100%;
        position: relative;
        z-index: 10;
      }
      /* ==========================================================================
         ARTICLE BODY
         Content wrapper with base typography styles
         ========================================================================== */
      .title-container {
        z-index: 10;
      }
      .articleBody {
        color: #f2f0eb;
        margin: 0 auto;
        width: 80%;
        display: flex;
        flex-direction: column;
        padding-top: 8rem;
        padding-bottom: 30vh;
        font-family: "Cormorant Garamond", serif;
      }

      .articleBody p {
        margin-bottom: 1.1rem;
        line-height: 1.6;
        font-size: 2rem;
      }

      /* ==========================================================================
         TYPOGRAPHY COMPONENTS
         Individual text elements with specific styling
         ========================================================================== */

      /* Main blog post title */
      .title {
        margin: 0;
        font-size: 2rem;
        font-weight: normal;
        font-family: "Space Grotesk", sans-serif;
        text-align: start;
        color: #f2f0eb;
        margin-bottom: 1rem;
      }

      /* Publication date display */
      .postDate {
        font-size: 0.5rem;
        font-family: "Space Grotesk", sans-serif;
        margin: 0 0 0 auto;
        color: #999;
        padding: 0;
      }

      /* Tools/metadata display (unused but kept for future use) */
      /* .tools {
        display: block;
        text-align: center;
        font-size: 0.7rem;
        font-family: "
            Cormorant Garamond "",
          serif;
        color: #fdfefe7f;
        padding-bottom: 2rem;
        font-style: italic;
      }
      */

      /* ==========================================================================
         RELATED ARTICLES CONTAINER
         Styling for the related articles section
         ========================================================================== */
      .related-container {
        margin: 0 auto;
      }

      /* ==========================================================================
         CONTENT ELEMENTS
         Styling for various content elements within articles
         ========================================================================== */

      /* Horizontal rule separator */
      hr {
        border: none;
        border-top: 1px solid #ddd;
        margin: 1rem 0;
      }

      /* ==========================================================================
         RESPONSIVE DESIGN
         Media queries for different screen sizes
         ========================================================================== */

      /* Large desktop screens */
      @media (min-width: 1921px) {
        .title {
          font-size: 3rem;
          line-height: 1;
        }
        .summary {
          font-size: 1.2rem;
        }
        .postDate {
          font-size: 0.8rem;
        }
        .articleContainer {
          font-size: 2rem;
          max-width: 60%;
          margin-top: 0 !important;
        }
        .articleBody {
          width: 60%;
          padding-top: 8rem;
        }
      }

      /* Desktop screens */
      @media (min-width: 1361px) and (max-width: 1920px) {
        .title {
          line-height: 1.2;
          font-size: 2.2em;
          line-height: 1;
          font-weight: bold;
        }
        .summary {
          font-size: 1.1rem;
        }
        .postDate {
          font-size: 0.8rem;
        }
        .top-container {
          width: 100%;
        }
        .articleContainer {
          font-size: 1.5rem;
          max-width: 60%;
          margin-top: 0 !important;
        }
        .articleBody {
          padding-top: 15vh;
        }
      }

      /* Tablet and small desktop */
      @media (min-width: 769px) and (max-width: 1360px) {
        .title {
          font-size: 3rem;
          line-height: 1.1;
        }

        .top-container {
          width: 100%;
        }
        .summary {
          font-size: 1.1rem;
        }
        .postDate {
          font-size: 0.8rem;
        }
        .articleContainer {
          font-size: 1.5rem;
          margin-top: 0 !important;
        }
        .articleBody {
          padding-top: 8rem;
        }
        .title-container {
          width: 90%;
        }
      }

      /* Mobile devices */
      @media (max-width: 768px) {
        .title-container {
          width: 100%;
          padding-right: 0;
        }
        .top-container {
          width: 100%;
        }
        .title {
          width: 100%;
          font-size: 2.4rem;
          line-height: 1.1;
          text-align: left;
        }
        .summary {
          font-size: 1rem;
          margin: 1rem 0;
        }
        .postDate {
          font-size: 0.7rem;
          text-align: left;
          margin: 1rem 0;
        }
        .articleContainer {
          flex-direction: column;
          max-width: 95%;
          font-size: 2rem;
          margin-top: 0 !important;
        }
        .articleBody {
          flex-direction: column;
        }
        .articleBody p {
          margin-bottom: 1rem;
          line-height: 1.5;
        }
        .top-container {
          height: auto;
          padding: 2rem 0;
        }
        .related-container {
          position: relative;
          width: 100%;
          padding: 1rem 0;
        }
      }

      /* Small mobile devices */
      @media (max-width: 480px) {
        .title {
          font-size: 2.4rem;
          line-height: 1.2;
          padding: 1rem 0;
        }
        .summary {
          font-size: 0.9rem;
        }
        .postDate {
          font-size: 0.6rem;
        }
        .articleContainer {
          max-width: 100%;
          font-size: 1.5rem;
          margin-top: 0 !important;
        }
        .articleBody {
          padding: 0 0.5rem;
        }
        .articleBody p {
          margin-bottom: 0.8rem;
          line-height: 1.4;
        }
        .top-container {
          padding: 1rem 0;
        }
        .related-container {
          position: relative;
          width: 100%;
          padding: 0.5rem 0;
        }
      }
    </style>
  </body>
</html>
