---
import { SITE_TITLE } from "../consts";
import BaseHead from "../components/BaseHead.astro";
import ModifiedHeader from "@/components/ModifiedHeader.astro";
import Ornaments from "@/components/Ornaments.astro";
import Footer from "@/components/Footer/Footer.astro";

// Fetch photos from Are.na channels
const channelSlugs = [
  "fotodiario-2026",
  "fotodiario-2025",
  "fotos-favoritas-de-anos",
];

interface ArenaBlock {
  class: string;
  image?: {
    display: {
      url: string;
    };
    thumb: {
      url: string;
    };
    original: {
      url: string;
    };
  };
  title?: string;
  id: number;
  connected_at?: string;
}

interface ArenaResponse {
  contents: ArenaBlock[];
  length: number;
  total_pages: number;
  current_page: number;
  per: number;
}

// Fetch first page from a single channel (limited to reduce API requests)
async function fetchFromChannel(slug: string): Promise<ArenaBlock[]> {
  const url = `https://api.are.na/v2/channels/${slug}/contents?page=1&per=62`;
  const response = await fetch(url, {
    headers: {
      Accept: "application/json",
      "User-Agent": "Animanoir-Website/1.0",
    },
  });

  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status} for ${slug}`);
  }

  const data: ArenaResponse = await response.json();

  // Filter for image blocks only
  const imageBlocks =
    data.contents?.filter(
      (block: ArenaBlock) => block.class === "Image" && block.image,
    ) || [];

  return imageBlocks.sort((a, b) => {
    const aDate = a.connected_at ? new Date(a.connected_at).getTime() : 0;
    const bDate = b.connected_at ? new Date(b.connected_at).getTime() : 0;

    if (aDate === bDate) {
      return b.id - a.id;
    }

    return bDate - aDate;
  });
}

let photos: ArenaBlock[] = [];

try {
  // Fetch all photos from each channel
  const results = await Promise.all(
    channelSlugs.map((slug) => fetchFromChannel(slug)),
  );

  // Combine photos and reverse to show newest first
  photos = results.flat();
} catch (error) {
  console.error("Error fetching Are.na photos:", error);
}
---

<html lang="es">
  <head>
    <BaseHead
      title="Photodiary"
      description="Photo diary capturing the daily surrealness of life — moments, textures, and fleeting beauty."
      image="/images/photodiary.jpg"
      lang="es"
      ogLocale="es_ES"
    />
  </head>

  <body>
    <h1 class="visually-hidden">
      Photodiary — Daily Surreal Photography by Óscar A. Montiel
    </h1>
    <Ornaments />
    <ModifiedHeader />
    <div class="photo-grid">
      {
        photos.map((photo) => (
          <div class="photo-item">
            <a
              href={`https://www.are.na/block/${photo.id}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <img
                src={photo.image?.display?.url || photo.image?.original?.url}
                alt={photo.title || `Photo ${photo.id}`}
                loading="lazy"
                decoding="async"
              />
            </a>
          </div>
        ))
      }
    </div>

    <div class="more-photos">
      <p>
        To see more photos from previous years, visit{" "}
        <a
          href="https://www.are.na/tilde-colon-pipe-degrees-degrees-bullet-period-pipe-colon-tilde/atras-gris-panteismo-infiernos-y-claraboyas"
          target="_blank"
          rel="noopener noreferrer"
        >
          Atrás gris: panteísmo, infiernos y claraboyas (fotodiarios)
        </a>
      </p>
    </div>

    <Footer useTopOffset={false} />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
      }

      .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(390px, 1fr));
        gap: 0;
        width: 100%;
        min-height: 100vh;
      }

      .photo-item {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 100%; /* Square aspect ratio */
        overflow: hidden;
        background: #000;
      }

      .photo-item a {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: block;
      }

      .photo-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.8s ease;
      }

      .photo-item img.revealed {
        opacity: 1;
        transition: none;
      }

      .photo-item:hover img {
        filter: invert(1);
      }

      .more-photos {
        width: 100%;
        padding: 4rem 2rem;
        background: #f2f0eb;
        text-align: center;
        font-family: "Montserrat", sans-serif;
      }

      .more-photos p {
        color: #1c1c1c;
        font-size: 1rem;
        line-height: 1.5;
        margin: 0;
      }

      .more-photos a {
        color: #1c1c1c;
        text-decoration: underline;
        transition: opacity 0.3s ease;
      }

      .more-photos a:hover {
        opacity: 0.7;
      }

      @media (max-width: 768px) {
        .photo-grid {
          grid-template-columns: repeat(
            auto-fit,
            minmax(min(150px, 100%), 1fr)
          );
          padding-top: 8vh;
        }

        .more-photos {
          padding: 2rem 1.5rem;
        }

        .more-photos p {
          font-size: 0.9rem;
        }
      }

      @media (min-width: 1920px) {
        .photo-grid {
          grid-template-columns: repeat(auto-fit, minmax(520px, 1fr));
        }
      }
    </style>

    <script>
      function initPhotodiary() {
        const imgs = document.querySelectorAll(".photo-item img");
        if (!imgs.length) return;

        // Retrieve set of already-revealed image URLs from session
        const STORAGE_KEY = "photodiary-revealed";
        let revealedSet: Set<string>;
        try {
          const stored = sessionStorage.getItem(STORAGE_KEY);
          revealedSet = stored ? new Set(JSON.parse(stored)) : new Set();
        } catch {
          revealedSet = new Set();
        }

        function persistRevealed() {
          try {
            sessionStorage.setItem(
              STORAGE_KEY,
              JSON.stringify([...revealedSet]),
            );
          } catch {
            /* ignore quota errors */
          }
        }

        // Immediately reveal images that were already seen
        const unseenImgs: HTMLImageElement[] = [];
        imgs.forEach((img) => {
          const src = (img as HTMLImageElement).src;
          if (revealedSet.has(src)) {
            (img as HTMLImageElement).classList.add("revealed");
          } else {
            unseenImgs.push(img as HTMLImageElement);
          }
        });

        if (!unseenImgs.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const img = entry.target as HTMLImageElement;
              const delay = Math.random() * 1500; // 0–1.5s random delay

              observer.unobserve(img);

              setTimeout(() => {
                img.style.opacity = "1";

                // After the CSS transition ends, clean up
                img.addEventListener(
                  "transitionend",
                  () => {
                    img.style.opacity = "";
                    img.style.transition = "";
                    img.classList.add("revealed");
                    revealedSet.add(img.src);
                    persistRevealed();
                  },
                  { once: true },
                );
              }, delay);
            });
          },
          { threshold: 0.1 },
        );

        unseenImgs.forEach((img) => observer.observe(img));
      }

      // Run on first load and every View Transitions navigation
      document.addEventListener("astro:page-load", initPhotodiary);
    </script>
  </body>
</html>
