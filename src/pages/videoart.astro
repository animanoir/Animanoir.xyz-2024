---
import BaseHead from "@/components/BaseHead.astro";
import ModifiedHeader from "@/components/ModifiedHeader.astro";
import Footer from "@/components/Footer/Footer.astro";
import { YouTube } from "astro-embed";
import videoartCover from "@/images/works/videoart.png";
---

<html lang="en">
  <head>
    <BaseHead
      title="Videoart"
      description={"Videoart by Óscar A. Montiel."}
      image={videoartCover.src}
    />
  </head>
  <body>
    <ModifiedHeader />
    <main>
      <article class="articleContainer">
        <div class="articleBody">
          <h1 class="page-title">Video Art</h1>

          <YouTube id="https://www.youtube.com/watch?v=15PnoZ63I0U" />
          <YouTube id="https://www.youtube.com/watch?v=Hv3F1eRYVNY" />
          <YouTube id="https://www.youtube.com/watch?v=53mO61hIEOU" />
          <YouTube id="https://www.youtube.com/watch?v=HLnraLAKT3M" />
          <YouTube id="https://www.youtube.com/watch?v=S2-rMxZCKZs" />

          <p class="youtube-link">
            To view more, you can visit my YouTube site: <a
              href="https://www.youtube.com/@animanoir"
              target="_blank"
              rel="noopener noreferrer">https://www.youtube.com/@animanoir</a
            >
          </p>
        </div>
      </article>
    </main>
    <Footer useTopOffset={false} />
  </body><style>
    body {
      margin: 0;
      overflow-x: hidden;
    }

    main {
      margin-left: 10vw;
    }

    .page-title {
      font-family: "Bebas Neue", sans-serif;
      font-size: 4rem;
      color: #1c1c1c;
      margin-bottom: 2rem;
    }

    .articleContainer {
      padding-bottom: 40vh;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .articleBody {
      font-family: "Cormorant Garamond", serif;
      color: #1c1c1c;
      font-size: 1.3rem;
      width: 90%;
      margin: 0 auto;
      line-height: 1.8;
    }

    .articleBody :global(lite-youtube) {
      margin: 3.6rem 0 !important;
    }

    .youtube-link {
      color: #1c1c1c;
      font-family: "Bebas Neue", sans-serif;
      font-size: 1.25rem;
      margin-top: 3rem;
    }

    .youtube-link a {
      color: #1c1c1c;
      text-decoration: underline;
      transition: opacity 0.2s ease;
    }

    .youtube-link a:hover {
      opacity: 0.7;
    }

    @media (max-width: 1920px) {
      .articleContainer {
        width: 60%;
      }
    }

    @media (max-width: 768px) {
      main {
        margin-left: 0;
      }
      .articleContainer {
        width: 100%;
      }
      .articleBody {
        width: 95%;
        font-size: 1.1rem;
      }
      .page-title {
        font-size: 2.5rem;
      }
    }

    @media (max-width: 480px) {
      .articleContainer {
        width: 100%;
        padding-top: 5vh;
        padding-bottom: 20vh;
      }
      .articleBody {
        width: 100%;
        padding: 0 1rem;
        box-sizing: border-box;
        font-size: 1rem;
      }
      .page-title {
        font-size: 2rem;
      }
    }
  </style>
</html>
