---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";
import { getAllPosts } from "../../lib/sanity";

const posts = await getAllPosts();

// Group posts by year
const postsByYear = posts.reduce(
  (acc, post) => {
    const year = new Date(post.publishedAt).getFullYear();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push(post);
    return acc;
  },
  {} as Record<number, typeof posts>,
);

// Sort years in descending order (newest first)
const sortedYears = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Blog"
      description={"Blog & studies about subjects I find interesting and fun. Expect random, weird and probably confusing thoughts."}
    />
  </head>
  <body>
    <Header />
    <main>
      <div class="vertical-scroll-wrapper">
        <div class="blogpostsContainer">
          <!-- Posts grouped by year -->
          {
            sortedYears.map((year) => (
              <div class="year-section" data-year={year}>
                {postsByYear[year].map((post) => (
                  <div class="random-position post-item" data-year={year}>
                    <small class="postDate">
                      {new Date(post.publishedAt).toLocaleDateString()}
                    </small>
                    <a data-astro-prefetch href={`/blog/${post.slug.current}/`}>
                      <div class="postInfo">
                        <p class="postTitle">{post.title}</p>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </main>
    <style>
      main {
        width: 100%;
        min-height: 100vh;
        overflow-x: hidden;
      }

      .blogpostsContainer {
        position: relative;
        max-width: 1200px;
        margin: 0 auto;
        padding-top: 100px;
        padding-bottom: 20vh;
      }

      .year-section {
        position: relative;
        width: 100%;
        min-height: 60vh;
      }

      .random-position {
        position: absolute;
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
        max-width: 350px;
        z-index: 1;
      }

      .postDate {
        font-family: "Open Sans", sans-serif;
        font-size: 0.8rem;
        margin: 0;
        color: #484848;
      }

      a {
        text-decoration: none;
      }

      a:hover {
        filter: invert(1);
      }

      .postTitle {
        background-color: rgba(0, 0, 0, 0);
        color: floralwhite;
        font-family: "Montserrat", sans-serif;
        font-size: 1.1rem;
        line-height: 1.4;
        width: fit-content;
        padding-top: 0;
      }

      .postInfo {
        mix-blend-mode: exclusion;
      }

      @media (max-width: 768px) {
        .blogpostsContainer {
          padding-left: 20px;
          padding-right: 20px;
          padding-top: 120px;
        }

        .year-section {
          min-height: auto !important;
          height: auto !important;
          display: flex;
          flex-direction: column;
          gap: 40px;
          margin-bottom: 60px;
        }

        .random-position {
          position: static;
          opacity: 1;
          max-width: 100%;
        }

        .year-markers {
          display: none;
        }
      }
    </style>
    <script>
      function initVerticalScroll() {
        const container = document.querySelector(".blogpostsContainer");
        if (!container) return;

        const sections = document.querySelectorAll(".year-section");
        const posts = document.querySelectorAll(".random-position");

        // Mobile Reset
        if (window.innerWidth <= 768) {
          posts.forEach((p) => {
            const el = p as HTMLElement;
            el.style.removeProperty("top");
            el.style.removeProperty("left");
            el.style.opacity = "1";
          });
          sections.forEach((s) =>
            (s as HTMLElement).style.removeProperty("height"),
          );
          return;
        }

        // Desktop Positioning
        sections.forEach((section) => {
          const secEl = section as HTMLElement;
          const items = secEl.querySelectorAll(".post-item");

          if (items.length === 0) return;

          // Calculate needed height roughly
          const heightVal = Math.max(80, items.length * 25);
          secEl.style.height = `${heightVal}vh`;

          const w = secEl.offsetWidth;
          const h = secEl.offsetHeight;

          items.forEach((item, i) => {
            const el = item as HTMLElement;
            const x = Math.random() * (w - 400);
            const y = Math.random() * (h - 200) + 50;

            el.style.left = `${Math.max(0, x)}px`;
            el.style.top = `${y}px`;

            setTimeout(() => {
              el.style.opacity = "1";
            }, i * 150);
          });
        });

        // Year Marker Logic
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const y = (entry.target as HTMLElement).dataset.year;
                document.querySelectorAll(".year-marker").forEach((m) => {
                  const mEl = m as HTMLElement;
                  if (mEl.dataset.year === y) mEl.classList.add("active");
                  else mEl.classList.remove("active");
                });
              }
            });
          },
          {
            rootMargin: "-45% 0px -45% 0px",
          },
        );

        sections.forEach((s) => observer.observe(s));
      }

      document.addEventListener("astro:page-load", initVerticalScroll);
      document.addEventListener("DOMContentLoaded", initVerticalScroll);

      let resizeTimer: number;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(initVerticalScroll, 200) as unknown as number;
      });
    </script>
  </body>
</html>
