---
import BaseHead from "../components/BaseHead.astro";
import ModifiedHeader from "@/components/ModifiedHeader.astro";
import video from "@/images/about/oscar-a-montiel.webm";
import { Image } from "astro:assets";
import "../styles/global.css";

import arenaLogo from "@/components/Footer/icons/arena-logo-white.png";
import youtubeSvg from "@/components/Footer/icons/youtube.svg";
import steamSvg from "@/components/Footer/icons/steam.svg";
import linkedinSvg from "@/components/Footer/icons/linkedin.svg";

const socialLinks = [
  {
    href: "https://www.are.na/tilde-colon-pipe-degrees-degrees-bullet-period-pipe-colon-tilde/channels",
    icon: arenaLogo,
    label: "Are.na",
  },
  {
    href: "https://www.youtube.com/channel/UCGe1qc0nF0uNypETYDQmMMQ",
    icon: youtubeSvg,
    label: "YouTube",
  },
  {
    href: "https://steamcommunity.com/id/geosmina/",
    icon: steamSvg,
    label: "Steam",
  },
  {
    href: "https://www.linkedin.com/in/oscaramontiel/",
    icon: linkedinSvg,
    label: "LinkedIn",
  },
];
---

<head>
  <BaseHead
    title="Hola, dicen que soy Óscar"
    description={"Interactive Media Artist. Videoart, videogames, music, and interactive 3D."}
    image="/images/about/óscar-a-montiel-animanoir-geosmina.jpg"
  />
  <link rel="preload" as="video" href={video} />
</head>

<body>
  <ModifiedHeader goWild={true} sortSpeed={80.0} />
  <div class="about-container">
    <video
      class="main-image"
      src={video}
      autoplay
      loop
      muted
      playsinline
      width={500}
      height={500}></video>
    <h1 class="name">Óscar A. Montiel</h1>
    <div class="social-row">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            class="social-link"
          >
            <Image
              src={link.icon}
              alt={link.label}
              class="social-icon"
              loading="eager"
            />
            <span>{link.label}</span>
          </a>
        ))
      }
    </div>
  </div>
  <style>
    .about-container {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      color: #1c1c1c;
      font-family: "Bebas Neue", sans-serif;
    }

    .main-image {
      display: block;
      max-width: 450px;
      width: 100%;
      height: auto;
    }

    .name {
      font-size: 2rem;
      font-weight: 600;
      margin: 1.5rem 0 0.25rem;
      font-family: "Bebas Neue", sans-serif;
      display: none;
    }

    .title {
      font-size: 1rem;
      color: #b0b0b0;
      margin: 0;
      padding: 0;
      font-weight: 400;
    }

    .social-row {
      display: flex;
      gap: 2rem;
      margin-top: 2rem;
      align-items: center;
      flex-wrap: wrap;
      justify-content: center;
    }

    .social-link {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: #1c1c1c;
      text-decoration: none;
      font-size: 0.85rem;
      transition: opacity 0.3s;
    }

    .social-link:hover {
      opacity: 0.6;
    }

    .social-icon {
      height: 18px;
      width: auto;
      filter: brightness(0.11);
    }

    @media (max-width: 767.98px) {
      .about-container {
        position: static;
        transform: none;
        margin: 6rem auto 2rem;
        padding: 0 1.5rem;
      }

      .main-image {
        max-width: 280px;
      }

      .name {
        font-size: 1.6rem;
      }

      .social-row {
        gap: 1.5rem;
      }
    }
  </style>
</body>
