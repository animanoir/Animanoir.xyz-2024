      <style>
        :global(body) {
          background-color: transparent !important;
        }

        .scene-background {
          position: fixed;
          top: 0;
          left: 0;
          width: 100vw;
          height: 100vh;
          z-index: 0;
        }

        .scene-background :global(#fiberCanvas) {
          position: fixed;
          width: 100vw;
          height: 100vh;
        }

        .scene-spacer {
          width: 100%;
          height: 100vh;
          pointer-events: none;
        }

        main {
          position: relative;
          z-index: 1;
          margin-left: 10vw;
          pointer-events: none;
        }

        .projectsContainer {
          pointer-events: auto;
        }

        .scroll-indicator {
          display: none;
        }
        /* ==========================================================================
     BACKGROUND VIDEO STYLES
     Components for floating background video elements
     ========================================================================== */

        .background-videos {
          position: fixed;
          top: 0;
          left: 0;
          width: 10%;
          height: 20%;
          z-index: 100;
          pointer-events: none;
          overflow: hidden;
        }

        .bg-video-container {
          position: absolute;
          width: 200px;
          height: 150px;
          opacity: 0.15;
          animation: float 10s ease-in-out infinite;
        }

        /* Floating animation for background video containers */
        @keyframes float {
          0%,
          100% {
            transform: translateY(0px) rotate(0deg);
          }
          50% {
            transform: translateY(-20px) rotate(5deg);
          }
        }

        /* Entry animation for background videos */
        @keyframes fadeInFloat {
          0% {
            opacity: 0;
            transform: translateY(30px) scale(0.8);
          }
          100% {
            opacity: 0.15;
            transform: translateY(0px) scale(1);
          }
        }

        /* ==========================================================================
     VIDEO GRADIENT WRAPPER
     Full viewport height video container
     ========================================================================== */

        .video-gradient-wrapper {
          width: 100%;
          height: 100vh;
          overflow: hidden;
        }

        .video-gradient-wrapper :global(video) {
          width: 100%;
          height: 100vh;
          object-fit: cover;
        }

        /* ==========================================================================
     VIDEO GRID LAYOUT
     Main video showcase grid system
     ========================================================================== */

        .videogrid-container {
          min-height: 100vh;
          display: flex;
          justify-content: center;
          align-items: center;
          box-sizing: border-box;
          padding: 0 2rem;
        }

        .videogrid {
          margin: 0 auto;
          display: grid;
          grid-template-columns: 1.2fr 0.8fr 1fr;
          grid-template-rows: auto auto;
          gap: 0.5rem;
          position: relative;
        }

        /* Artistic asymmetric positioning for each video */
        .videogrid > :global(*:nth-child(1)) {
          aspect-ratio: 4 / 3;
          transform: rotate(-2deg) translateY(10%);
          border-radius: 8px;
          overflow: hidden;
          box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
          transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s ease;
        }

        .videogrid > :global(*:nth-child(1):hover) {
          transform: rotate(0deg) translateY(5%) scale(1.02);
          box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.6);
        }

        .videogrid > :global(*:nth-child(2)) {
          aspect-ratio: 1 / 1;
          transform: rotate(3deg) translateY(-15%);
          border-radius: 8px;
          overflow: hidden;
          box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.4);
          transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s ease;
        }

        .videogrid > :global(*:nth-child(2):hover) {
          transform: rotate(0deg) translateY(-10%) scale(1.02);
          box-shadow: 0 30px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .videogrid > :global(*:nth-child(3)) {
          aspect-ratio: 16 / 10;
          transform: rotate(-1deg) translateY(25%);
          border-radius: 8px;
          overflow: hidden;
          box-shadow: 0 30px 55px -15px rgba(0, 0, 0, 0.45);
          grid-row: span 1;
          transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s ease;
        }

        .videogrid > :global(*:nth-child(3):hover) {
          transform: rotate(0deg) translateY(20%) scale(1.02);
          box-shadow: 0 40px 65px -18px rgba(0, 0, 0, 0.55);
        }

        .videogrid > :global(*) {
          overflow: hidden;
        }

        .single-video {
          width: 10%;
          height: 20%;
          z-index: -1;
        }

        /* ==========================================================================
     HERO SECTION
     Main quote and introduction section
     ========================================================================== */

        .quote-container {
          width: 100%;
          height: 100vh;
          display: flex;
          justify-content: center;
          align-items: center;
          box-sizing: border-box;
        }

        .quote {
          font-family: "Montserrat", sans-serif;
          font-size: 3.5rem;
          text-align: justify;
          line-height: 1.35;
          font-weight: 500;
          margin: 0;
          max-width: 70%;
        }

        /* ==========================================================================
     PROJECTS CONTAINER
     Main container for all project sections
     ========================================================================== */

        .projectsContainer {
          width: 100%;
          box-sizing: border-box;
          padding: 0 var(--page-padding, 6%);
          margin: 0 auto;
          overflow-y: hidden;
        }

        /* ==========================================================================
     SECTION LAYOUT
     Individual work category sections
     ========================================================================== */

        .listContainer {
          min-height: 100vh;
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;
          text-align: center;
          box-sizing: border-box;
        }

        /* ==========================================================================
     TYPOGRAPHY
     Text styles for headings and content
     ========================================================================== */

        .postTitle,
        .year {
          font-family: "Montserrat", sans-serif;
          color: floralwhite;
          margin: 0;
          padding: 0;
        }

        .workType {
          font-family: "Bebas Neue", sans-serif;
          font-size: 3.5rem;
          text-align: center;
          z-index: 100;
          font-weight: 600;
          line-height: 1.2;
          margin-bottom: 1.5rem;
          color: floralwhite;
          margin: 0;
          padding: 0;
          margin-bottom: 1.5rem;
          text-shadow:
            0 2px 8px rgba(0, 0, 0, 0.8),
            0 0 20px rgba(0, 0, 0, 0.6);
        }

        .postTitle {
          line-height: 1.25;
          text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
          font-weight: 500;
          text-align: initial;
          font-size: 2rem;
        }

        .year {
          font-size: 0.9rem;
          text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
          font-weight: 400;
        }

        /* ==========================================================================
     PROJECT GRID
     Grid layout for project thumbnails
     ========================================================================== */

        ul {
          list-style-type: none;
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 0.5rem;
          width: 60vw;
          max-width: 1800px;
          justify-content: center;
          height: auto;
        }

        ul li {
          display: flex;
          justify-content: center;
        }

        .project {
          height: 100%;
          width: 100%;
          background-color: rgba(0, 0, 0, 0.7);
          border-radius: 0.5rem;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
          overflow: hidden;
        }

        /* ==========================================================================
     PROJECT CARDS
     Individual project card styling and interactions
     ========================================================================== */

        ul a {
          height: 100%;
          position: relative;
        }

        ul a:hover {
          filter: invert(1);
        }

        .postHeroImg {
          height: 100%;
          width: 100%;
          object-fit: cover;
          opacity: 0;
          transition: opacity 0.5s ease-in-out;
        }

        .postHeroImg.loaded {
          opacity: 1;
        }

        /* Project info overlay - appears on hover */
        .postInfo {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          z-index: 10;
        }

        .project:hover .postInfo {
          display: block;
        }

        /* ==========================================================================
     ANIMATED GRADIENT TEXT
     Gradient animations for highlighted text elements
     ========================================================================== */

        @keyframes gradient-flow {
          0% {
            background-position: 0% 50%;
          }
          50% {
            background-position: 100% 50%;
          }
          100% {
            background-position: 0% 50%;
          }
        }

        .animated-gradient-text {
          background-image: linear-gradient(
            90deg,
            #ec4899,
            #f97316,
            #eab308,
            #84cc16,
            #22c55e,
            #14b8a6,
            #0ea5e9,
            #6366f1,
            #a855f7,
            #ec4899
          );
          background-size: 200% auto;
          -webkit-background-clip: text;
          background-clip: text;
          color: transparent;
          animation: gradient-flow 5s linear infinite;
          cursor: default;
        }

        /* ==========================================================================
     RESPONSIVE DESIGN
     Media queries for different screen sizes
     ========================================================================== */

        /* Small mobile screens - hide excess background videos */
        @media (max-width: 480px) {
          .bg-video-container:nth-child(n + 4) {
            display: none;
          }
        }

        /* Mobile and tablet styles */
        @media (max-width: 760px) {
          .scroll-indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #fdfefe;
            font-family: "Bebas Neue", sans-serif;
            font-size: 1.2rem;
            opacity: 0.7;
            margin-bottom: 5rem;
            margin-top: -15vh;
            animation: bounce 2s infinite;
          }

          @keyframes bounce {
            0%,
            20%,
            50%,
            80%,
            100% {
              transform: translateY(0);
            }
            40% {
              transform: translateY(-10px);
            }
            60% {
              transform: translateY(-5px);
            }
          }
          main {
            margin-left: 0;
            width: 100%;
            margin-top: 40%;
          }

          .quote {
            font-size: 2rem !important;
            padding: 0 1rem;
            max-width: 100%;
          }

          .video-gradient-wrapper {
            display: none;
          }

          .projectsContainer {
            width: 90%;
            padding: 0;
            margin: 0 auto;
            box-sizing: border-box;
            overflow-x: hidden;
          }

          .listContainer {
            min-height: auto;
            padding: 2rem 0;
            width: 100%;
          }

          .workType {
            font-size: 2.25rem;
            transform: none;
            padding: 0;
            text-align: left;
            margin-bottom: 2rem;
          }

          ul {
            width: 90vw;
            grid-template-columns: 1fr;
            padding: 0;
            box-sizing: border-box;
            gap: 2rem;
          }

          .project {
            opacity: 1;
            width: 100%;
            margin-bottom: 1rem;
          }

          ul a {
            display: block;
            width: 100%;
          }

          .postHeroImg {
            opacity: 0.7;
            width: 100%;
            height: 100%;
            object-fit: cover;
          }

          .postInfo {
            display: block;
            background-color: rgba(0, 0, 0, 0.5);
            padding: 0.5rem;
            border-radius: 4px;
          }

          .postTitle {
            font-size: 1.4rem;
          }
        }

        /* Tablet responsive for video grid */
        @media (max-width: 768px) {
          .videogrid-container {
            padding: 2rem 1rem;
          }

          .videogrid {
            width: 100%;
            grid-template-columns: 1fr;
            gap: 2rem;
          }

          .videogrid > :global(*:nth-child(1)) {
            transform: rotate(-1deg);
            aspect-ratio: 16 / 9;
          }

          .videogrid > :global(*:nth-child(2)) {
            transform: rotate(1.5deg) translateX(5%);
            aspect-ratio: 16 / 9;
          }

          .videogrid > :global(*:nth-child(3)) {
            transform: rotate(-0.5deg) translateX(-3%);
            aspect-ratio: 16 / 9;
          }
        }

        /* Standard HD screens - slightly reduced text sizes */
        @media (max-width: 1920px) {
          .quote {
            font-size: 2.5rem;
          }

          .workType {
            font-size: 2.8rem;
          }

          .postTitle {
            font-size: 1.5rem;
            text-align: center;
          }
        }

        /* Large desktop screens */
        @media (min-width: 1080px) {
          .quote {
            max-width: 50%;
          }
        }

        /* Ultra-wide screens */
        @media (min-width: 1921px) {
          .mainquote {
            font-size: 4rem;
          }
        }

        /* Video gradient wrapper */
        .video-gradient-wrapper {
          position: relative;
        }

